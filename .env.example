APP_NAME=MiniMax API Plan
APP_VERSION=1.0.0
APP_DEBUG=false
APP_ALLOWED_ORIGINS=["*"]
APP_LOG_DIR=logs
APP_LOG_LEVEL=INFO
APP_LOG_TO_FILE=true
APP_LOG_TO_CONSOLE=true

MINIMAX_API_KEY=your_api_key_here
MINIMAX_GROUP_ID=your_group_id_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1/text/chatcompletion_v2
MINIMAX_DEFAULT_MODEL=MiniMax-M2.7
MINIMAX_TIMEOUT=120.0

EVALUATION_ENABLED=false
EVALUATION_MODEL=MiniMax-M2.7

DB_DRIVER=mysql+aiomysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_db_password
DB_DATABASE=minimax_api_plan
DB_CHARSET=utf8mb4
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE=3600
DB_ECHO=false
